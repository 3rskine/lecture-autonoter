    {
      "parameters": {
        "jsCode": "const stdout = $input.first().json.stdout?.trim();\nif (!stdout) return [];\n\nconst filePath = stdout;\nconst parts = filePath.split('/');\nconst filename = parts[parts.length - 1];\nlet category = parts[parts.length - 2];\n\n// 如果在 會議 子資料夾下，category 補上 會議_ 前綴\nif (parts.includes('會議') && category !== '會議') {\n  category = `會議_${category}`;\n}\n\nconsole.log(`找到待處理檔案：${category}/${filename}`);\nreturn [{ json: { body: { category, filename }, filePath } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -10448,
        1168
      ],
      "id": "afb360d2-3845-498e-96a0-360fadb492de",
      "name": "Code in JavaScript1"
